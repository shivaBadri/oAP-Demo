# ---------------------------------------------------------------------------
# Database — PostgreSQL (Neon)
# Use the POOLED connection string for the app (host contains "-pooler").
#
# SECURITY: this file is committed. Never put a real password in it. The
# previous version of this file contained a live Neon credential — if that
# database is still in use, rotate it.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST.aws.neon.tech/DBNAME?sslmode=require"

# Migrations only. Neon's pooled endpoint cannot run DDL, so point this at the
# DIRECT (non-pooled) host — the one WITHOUT "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST.aws.neon.tech/DBNAME?sslmode=require"

# ---------------------------------------------------------------------------
# Auth — signs the admin session JWT.
# Generate with:  openssl rand -base64 32
# There is a dev fallback in code. Leaving this unset in production means
# anyone can forge an admin session. Set it.
# ---------------------------------------------------------------------------
AUTH_SECRET="replace-with-a-long-random-secret"

# ---------------------------------------------------------------------------
# Cloudinary — Dashboard > Account Details
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---------------------------------------------------------------------------
# Public site origin. Used for sitemap.xml, robots.txt and OpenGraph URLs.
# No trailing slash.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# ADMIN ADDRESS — the one switch between the two deployment modes.
#
# PATH MODE (default). Leave unset, or set it to the public origin.
#   The admin lives at  https://ownaplot.com/admin/login
#
#   NEXT_PUBLIC_ADMIN_URL=""
#
# SUBDOMAIN MODE. Set it to a DIFFERENT hostname.
#   The admin lives at  https://admin.ownaplot.com/login
#   Middleware rewrites that host's root onto /admin/* internally, so the
#   routes, guards and session cookie are identical in both modes.
#
#   NEXT_PUBLIC_ADMIN_URL="https://admin.ownaplot.com"
#
# Point the DNS record at the same deployment. No second build is needed.
# The public site's "Admin" link reads this variable — there are no hardcoded
# admin URLs anywhere in the codebase.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_ADMIN_URL=""

# Optional. Extra hostnames to treat as the admin, comma separated. Useful for
# preview deployments: "admin-staging.ownaplot.com,admin.localhost"
ADMIN_HOSTNAMES=""

# Optional override. In subdomain mode the session cookie is scoped to the
# registrable parent automatically (".ownaplot.com") so it is valid on both
# hosts. Set this only if that inference is wrong for your DNS.
SESSION_COOKIE_DOMAIN=""

# ---------------------------------------------------------------------------
# Seed only — creates the first SUPER_ADMIN account.
# Change the password after the first sign-in, then remove these.
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@ownaplot.com"
SEED_ADMIN_PASSWORD="changeme123"
